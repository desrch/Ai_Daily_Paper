# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_USE_MOCK_API=true
NEXT_PUBLIC_MOCK_API_ERROR=false
NEXT_PUBLIC_MOCK_EMAIL_ERROR=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI（兼容 DeepSeek 旧命名与新命名）
# 新版推荐：
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
# 旧版兼容：
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# 是否启用 AI 增强（默认 true；设为 false 则跳过 AI 调用）
AI_ENABLED=true

# 是否启用数据库存储（默认 true；设为 false 则仅使用内存/演示数据）
DATABASE_ENABLED=true

# News provider（当前后端使用 NEWS_API_KEY，未配置时回退到演示数据）
NEWS_API_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=

# Scheduled task authentication
CRON_SECRET=

# 演示用户 ID
DEMO_USER_ID=demo-user
